FROM python:3.11-slim
ENV PYTHONUNBUFFERED=1
WORKDIR /app
RUN pip install --no-cache-dir \
    yfinance \
    numpy \
    pandas \
    redis \
    psycopg2-binary \
    requests \
    beartype>=0.18.0 \
    scipy \
    hishel[httpx,async]>=1.0.0 \
    aiobreaker>=1.2.0 \
    tenacity>=8.2.0 \
    apscheduler>=3.10.0
# Code is volume-mounted from the host (same pattern as logger/analyzer)
CMD ["python", "-m", "trading_playbook.runner"]
