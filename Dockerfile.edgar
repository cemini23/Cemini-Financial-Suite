FROM python:3.11-slim
ENV PYTHONUNBUFFERED=1
WORKDIR /app
RUN pip install --no-cache-dir \
    httpx \
    redis \
    psycopg2-binary \
    pydantic \
    hishel[httpx,async]>=1.0.0 \
    aiobreaker>=1.2.0 \
    tenacity>=8.2.0 \
    apscheduler>=3.10.0 \
    beartype>=0.18.0
COPY . .
# Entry point set in docker-compose
