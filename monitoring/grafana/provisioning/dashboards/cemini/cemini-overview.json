{
  "title": "Cemini Overview",
  "uid": "cemini-overview",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["cemini", "overview"],
  "panels": [
    {
      "id": 1,
      "title": "Container CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[1m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "id": 2,
      "title": "Host Memory Usage",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Root Disk Usage",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_free_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Service Health (UP = 1)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Active Alerts",
      "type": "alertlist",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "datasource": "Alertmanager",
        "folder": { "id": 0, "title": "" },
        "groupBy": ["alertname"],
        "groupMode": "default",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "error": true, "firing": true, "noData": false, "normal": false, "pending": true }
      }
    },
    {
      "id": 6,
      "title": "Recent Container Logs",
      "type": "logs",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=~\"docker/.+\"} |= \"\" | line_format \"{{.container}} | {{.line}}\"",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 7,
      "title": "Data Pipeline Health — macro:fear_greed age",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "redis_key_ttl_seconds{key=\"macro:fear_greed\"}",
          "legendFormat": "FGI TTL",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 8,
      "title": "Redis Connected Clients",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Postgres Active Connections",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"qdb\"}",
          "legendFormat": "qdb connections",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "name": "DS_LOKI",
        "type": "datasource",
        "query": "loki",
        "current": { "text": "Loki", "value": "Loki" }
      }
    ]
  }
}
